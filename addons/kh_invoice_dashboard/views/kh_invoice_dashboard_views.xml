<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- Tree View -->
    <!-- ========================= -->
    <record id="view_kh_invoice_dashboard_tree" model="ir.ui.view">
        <field name="name">kh.invoice.dashboard.tree</field>
        <field name="model">kh.invoice.dashboard</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" class="o_kh_invoice_dashboard_list">
                <field name="company_id" string="Company"/>
                <field name="total_invoice" string="Total"/>
                <field name="draft_invoice" string="Draft"/>
                <field name="posted_invoice" string="Posted"/>
                <field name="paid_invoice" string="Paid"/>
                <field name="overdue_invoice" string="Overdue"/>
                <field name="total_sales" string="Total Sales (USD)" sum="Total Sales (USD)" widget="monetary"/>
                <field name="total_sales_khr" string="Total Sales (KHR)" sum="Total Sales (KHR)" widget="monetary"/>
                <field name="outstanding_amount" string="Outstanding (USD)" sum="Outstanding (USD)" widget="monetary"/>
                <field name="outstanding_amount_khr" string="Outstanding (KHR)" sum="Outstanding (KHR)" widget="monetary"/>
                <field name="last_updated" string="Last Updated"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="currency_id_khr" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Form View -->
    <!-- ========================= -->
    <record id="view_kh_invoice_dashboard_form" model="ir.ui.view">
        <field name="name">kh.invoice.dashboard.form</field>
        <field name="model">kh.invoice.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" delete="0">
                <sheet>

                    <group>
                        <field name="company_id" readonly="1"/>
                        <field name="last_updated" readonly="1"/>
                    </group>

                    <group string="Invoice Summary" col="4">
                        <field name="total_invoice" readonly="1"/>
                        <field name="draft_invoice" readonly="1"/>
                        <field name="posted_invoice" readonly="1"/>
                        <field name="paid_invoice" readonly="1"/>
                        <field name="overdue_invoice" readonly="1"/>
                    </group>

                    <field name="currency_id" invisible="1"/>
                    <field name="currency_id_khr" invisible="1"/>
                    <group string="Financial Summary" col="4">
                        <field name="total_sales" string="Total Sales (USD)" readonly="1" widget="monetary"/>
                        <field name="total_sales_khr" string="Total Sales (KHR)" readonly="1" widget="monetary"/>
                        <field name="outstanding_amount" string="Outstanding (USD)" readonly="1" widget="monetary"/>
                        <field name="outstanding_amount_khr" string="Outstanding (KHR)" readonly="1" widget="monetary"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Search View -->
    <!-- ========================= -->
    <record id="view_kh_invoice_dashboard_search" model="ir.ui.view">
        <field name="name">kh.invoice.dashboard.search</field>
        <field name="model">kh.invoice.dashboard</field>
        <field name="arch" type="xml">
            <search>
                <field name="company_id"/>
            </search>
        </field>
    </record>

</odoo>