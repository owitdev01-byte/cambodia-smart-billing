<odoo>
    <record id="view_move_form_khqr" model="ir.ui.view">
        <field name="name">account.move.form.khqr</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_confirm_khqr_payment" type="object" string="Mark as Paid"
                        class="oe_stat_button" icon="fa-check"
                        invisible="khqr_status != 'pending'"/>
            </xpath>
            <xpath expr="//field[@name='tax_totals']" position="after">
                <field name="alt_currency_id" invisible="1"/>
                <field name="alt_amount_total" widget="monetary"
                       string="Riel Equivalent"
                       invisible="not alt_currency_id"
                       options="{'currency_field': 'alt_currency_id'}"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="QR Payment" name="khqr_payment" invisible="move_type != 'out_invoice'">
                    <group>
                        <field name="khqr_status" widget="badge"
                               decoration-success="khqr_status == 'paid'"
                               decoration-warning="khqr_status == 'pending'"/>
                        <field name="khqr_qr_image" widget="image" nolabel="1"
                               readonly="state != 'posted'"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
