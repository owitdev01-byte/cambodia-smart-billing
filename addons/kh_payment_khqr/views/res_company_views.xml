<odoo>
    <record id="view_company_form_khqr" model="ir.ui.view">
        <field name="name">res.company.form.khqr</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Bakong KHQR" name="bakong_khqr">
                    <group>
                        <field name="bakong_account_id"/>
                        <field name="bakong_merchant_city"/>
                        <field name="bakong_merchant_category_code"/>
                        <field name="bakong_api_token" password="True"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
