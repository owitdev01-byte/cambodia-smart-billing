<odoo>
    <template id="report_invoice_document_khqr" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='total']" position="after">
            <div class="mt-2" t-if="o.alt_currency_id">
                <span>≈ <span t-out="o.alt_amount_total" t-options="{'widget': 'monetary', 'display_currency': o.alt_currency_id}"/></span>
            </div>
            <div class="mt-3" t-if="o.khqr_qr_image">
                <strong>Scan to Pay</strong>
                <br/>
                <img t-att-src="image_data_uri(o.khqr_qr_image)" style="width:140px;height:140px;"/>
            </div>
        </xpath>
    </template>
</odoo>
