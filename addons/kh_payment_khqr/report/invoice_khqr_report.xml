<odoo>
    <template id="report_invoice_document_khqr" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='total']" position="after">
            <div class="mt-3 p-3 border rounded" style="max-width: 280px;" t-if="o.alt_currency_id or o.khqr_qr_image">
                <div t-if="o.alt_currency_id" class="mb-2">
                    <span class="text-muted">Riel Equivalent: </span>
                    <strong t-out="'{:,.2f} {}'.format(o.alt_amount_total, o.alt_currency_id.name)"/>
                </div>
                <div t-if="o.khqr_qr_image" class="text-center">
                    <strong>Scan to Pay</strong>
                    <br/>
                    <img t-att-src="image_data_uri(o.khqr_qr_image)" style="width:120px;height:120px;"/>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
